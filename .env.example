THREADS_WEB_PORT=4173
THREADS_WEB_ADMIN_TOKEN=replace-with-strong-random-token
# Required for remote admin access. If omitted, /api/admin/* is loopback-only by default.
# THREADS_WEB_ADMIN_ALLOWLIST=127.0.0.1,10.0.0.5
# Optional but recommended when you place the admin UI behind a dedicated host.
# If set, /admin and /api/admin/* are only served on this origin.
# THREADS_WEB_ADMIN_ORIGIN=https://admin.threads-archive.dahanda.dev
# Optional: trust X-Forwarded-For only when the direct peer IP matches one of these values.
# Use this when the app is behind Nginx, a load balancer, or a reverse proxy.
# THREADS_WEB_TRUST_PROXY_ALLOWLIST=127.0.0.1,::1
# Optional: force the store backend. Defaults to file until explicitly set to postgres.
# THREADS_WEB_STORE_BACKEND=file
THREADS_WEB_DB_FILE=output/web-admin-data.json
# Optional: production store backend. Set THREADS_WEB_STORE_BACKEND=postgres to activate it.
# THREADS_WEB_POSTGRES_URL=postgres://user:password@localhost:5432/threads
# THREADS_WEB_DATABASE_URL=postgres://user:password@localhost:5432/threads
# THREADS_WEB_POSTGRES_TABLE=threads_web_store
# THREADS_WEB_POSTGRES_STORE_KEY=default
# Optional: postgres pool tuning
# THREADS_WEB_POSTGRES_MAX=10
# THREADS_WEB_POSTGRES_CONNECTION_TIMEOUT_MS=10000
# THREADS_WEB_POSTGRES_IDLE_TIMEOUT_MS=30000
# THREADS_WEB_POSTGRES_QUERY_TIMEOUT_MS=15000
# THREADS_WEB_POSTGRES_STATEMENT_TIMEOUT_MS=15000
THREADS_WEB_PUBLIC_ORIGIN=https://threads-archive.dahanda.dev
# Required: mention-bot public handle shown in scrapbook copy and emails
THREADS_BOT_HANDLE=replace-with-your-bot-handle
# Required for Threads OAuth scrapbook login
# THREADS_BOT_APP_ID=replace-with-threads-app-id
# THREADS_BOT_APP_SECRET=replace-with-threads-app-secret
# Optional: Graph version prefix for Threads API requests, for example v1.0
# THREADS_BOT_GRAPH_API_VERSION=
# Optional but recommended: dedicated secret for encrypting Threads scrapbook OAuth tokens
# THREADS_BOT_ENCRYPTION_SECRET=replace-with-strong-random-token
# Optional: override access token used by the background mention collector
# THREADS_BOT_MENTION_ACCESS_TOKEN=
# Optional: background mention collector tuning
# THREADS_BOT_MENTION_POLL_INTERVAL_MS=60000
# THREADS_BOT_MENTION_FETCH_LIMIT=25
# THREADS_BOT_MENTION_MAX_PAGES=5
# Required for server-side mention ingest webhook/API
THREADS_BOT_INGEST_TOKEN=replace-with-strong-random-token
# Optional: restrict server-side archive media fetches to these host suffixes
# THREADS_ARCHIVE_MEDIA_HOST_ALLOWLIST=threads.com,threads.net,cdninstagram.com,fbcdn.net
# Required for signing Pro keys. Provide either inline JSON or a file path.
THREADS_TO_OBSIDIAN_PRO_PRIVATE_JWK_FILE=output/pro-license-private.jwk
# THREADS_TO_OBSIDIAN_PRO_PRIVATE_JWK=
# Optional but recommended: dedicated secret for encrypting Notion OAuth tokens
# THREADS_NOTION_ENCRYPTION_SECRET=replace-with-strong-random-token
# Required for Notion OAuth
# THREADS_NOTION_CLIENT_ID=replace-with-notion-public-integration-client-id
# THREADS_NOTION_CLIENT_SECRET=replace-with-notion-public-integration-client-secret
# Optional request-size hardening for /api/* endpoints
THREADS_WEB_MAX_BODY_BYTES=1048576
# Required webhook credentials for enabled public payment providers
THREADS_WEBHOOK_SECRET_STABLEORDER=replace-with-stableorder-webhook-secret
THREADS_WEBHOOK_SECRET_STRIPE=replace-with-stripe-webhook-secret
# Required for PayPal webhook verification
# THREADS_PAYPAL_CLIENT_ID=replace-with-paypal-client-id
# THREADS_PAYPAL_CLIENT_SECRET=replace-with-paypal-client-secret
# THREADS_PAYPAL_WEBHOOK_ID=replace-with-paypal-webhook-id
# Optional: use sandbox when needed
# THREADS_PAYPAL_API_BASE_URL=https://api-m.sandbox.paypal.com
# Optional outbound HTTP timeout for provider APIs / Threads API / media fetches
# THREADS_WEB_FETCH_TIMEOUT_MS=15000
# Optional inbound HTTP/server hardening
# THREADS_WEB_REQUEST_TIMEOUT_MS=30000
# THREADS_WEB_HEADERS_TIMEOUT_MS=35000
# THREADS_WEB_KEEP_ALIVE_TIMEOUT_MS=5000
# THREADS_WEB_GRACEFUL_SHUTDOWN_TIMEOUT_MS=15000
# THREADS_WEB_RATE_LIMIT_BUCKET_LIMIT=50000
# Optional: SMTP auto-delivery (Pro key is emailed automatically when issued)
# If not set, admin must copy the email draft and send manually.
# THREADS_SMTP_HOST=smtp.gmail.com
# THREADS_SMTP_PORT=587
# THREADS_SMTP_SECURE=false
# THREADS_SMTP_USER=hello@oxcorp.ninja
# THREADS_SMTP_PASS=app-password-here
# THREADS_SMTP_FROM="OX Corp <hello@oxcorp.ninja>"
# Optional: unit price for revenue estimates (default: 19)
# THREADS_PRICE_USD=29
