{
  "manifest_version": 3,
  "name": "ss-threads",
  "description": "Save Threads posts to Obsidian or Notion, with ZIP fallback and optional AI organization.",
  "version": "0.1.0",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://www.threads.com/*",
    "https://www.threads.net/*",
    "https://ss-threads.dahanda.dev/*"
  ],
  "optional_host_permissions": [
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Save current Threads post",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "options_page": "options.html",
  "commands": {
    "save-current-post": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Save the current Threads post as Markdown"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.threads.com/*",
        "https://www.threads.net/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
