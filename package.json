  },
  "devDependencies": {
    "@types/chrome": "^0.0.306",
    "@types/jsdom": "^21.1.7",
    "@types/jszip": "^3.4.1",
    "@types/node": "^22.13.11",
    "esbuild": "^0.25.0",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}